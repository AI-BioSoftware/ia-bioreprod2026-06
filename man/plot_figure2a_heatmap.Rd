\name{plot_figure2a_heatmap}
\alias{plot_figure2a_heatmap}
\title{Draw a Figure 2A-style heatmap and save it to PDF}
\usage{plot_figure2a_heatmap(prepared, output_pdf, tick_times = c(0, 50, 100, 150, 200), width = 9, height = 12)}
\description{Draws a heatmap from the processed z-score matrix and writes it to PDF.}
